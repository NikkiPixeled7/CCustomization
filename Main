    eyesIMGID = canvasMiataCustom.create_image(375, 170, anchor='center', image=miataEyesPhoto)
    canvasMiataCustom.move(eyesIMGID, -134, -14)

def colourRemove():
    global miataEyesPhoto, eyesIMGID, eyes
    eyes = False
    print("Eyes Set: " + str(eyes))
    canvasMiataCustom.delete(eyesIMGID)

def colourClicked(event):
    global clickedB4
    clickedB4 += 1

    isOn = (clickedB4 % 2 == 1)

    animateButtonOnOff(canvasMCB4, isOn, "#178B26", "#0f5f1f")

    if isOn:
        colourAdd()
    else:
        colourRemove()

canvasMCB1.bind("<Button-1>", spoilerClicked)
canvasMCB2.bind("<Button-1>", skirtPackClicked)
canvasMCB3.bind("<Button-1>", rimsClicked)
canvasMCB4.bind("<Button-1>", colourClicked)

