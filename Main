# ------------ Back Arrow Def ------------

arrow_points = [
    100, 20,   # top right
    40, 20,    # start of arrow head
    40, 0,     # top tip
    0, 40,     # middle tip (pointing left)
    40, 80,    # bottom tip
    40, 60,    # bottom inner
    100, 60    # bottom right
]

def redBackArrow(parent, x=50, y=50):
    canvasArrow = Canvas(parent, width=120, height=80, bg="#1E1E1E", highlightthickness=0)
    canvasArrow.place(x=x, y=y)

    arrow = canvasArrow.create_polygon(arrow_points, fill="#CD2626", outline="black", width=2)

    arrowTxt = canvasArrow.create_text(0, 0, text="Back", font=("Courier New", 15, "bold"), fill='white')
    canvasArrow.move(arrowTxt, 55, 39)

    def goBack(event):
        animateButtonSC(canvasArrow, arrow, "#CD2626", "#a81f1f")
        canvasArrow.after(350, lambda: (showMainCanvases(), show_frame(mainGUI)))

    canvasArrow.bind("<Button-1>", goBack)

    return canvasArrow, arrow

