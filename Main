# ----------------- OVERLAP CHECK/FIX -------------------

def checkOverlap():
    global rims, spoiler, eyes, skirt, spIMGID, sprIMGID, rimsIMGID
    if sp == True and rims == True:
        canvasMiataCustom.delete(spIMGID)
        skirtPackAdd()
    if sp == False and rims == True:
        canvasMiataCustom.delete(spIMGID)
    if spr == True and rims == False:
        canvasMiataCustom.delete(sprIMGID)
        skirtPackAdd()

