# MCB = Miata Custom Button
canvasMCB1 = Canvas(canvasMiataCustom, width='150', height='65', bg='#178B26', highlightthickness=0)
canvasMCB2 = Canvas(canvasMiataCustom, width='150', height='65', bg='#178B26', highlightthickness=0)
canvasMCB3 = Canvas(canvasMiataCustom, width='150', height='65', bg='#178B26', highlightthickness=0)
canvasMCB4 = Canvas(canvasMiataCustom, width='150', height='65', bg='#178B26', highlightthickness=0)

spoilerText = canvasMCB1.create_text(0, 0, text="Spoiler", font=("Courier New", 25, "bold"), fill='white')
skirtText = canvasMCB2.create_text(0, 0, text="Skirt Pack", font=("Courier New", 17, "bold"), fill='white')
rimsText = canvasMCB3.create_text(0, 0, text="Rims", font=("Courier New", 25, "bold"), fill='white')
colourText = canvasMCB4.create_text(0, 0, text="Tired Eyes", font=("Courier New", 15, "bold"), fill='white')

def spoilerAdd():
    global miataSpoilerPhoto, spoilerIMGID, spoiler
    spoiler = True
    print("Spoiler Set: " + str(spoiler))
    miataSpoilerIMG = Image.open("spoilerMiata.png")
    miataSpoilerIMG = miataSpoilerIMG.resize((250, 165), Image.Resampling.LANCZOS)
    miataSpoilerPhoto = ImageTk.PhotoImage(miataSpoilerIMG)
    spoilerIMGID = canvasMiataCustom.create_image(375, 170, anchor='center', image=miataSpoilerPhoto)
    canvasMiataCustom.move(spoilerIMGID, 175, -68)
def spoilerRemove():
    global miataSpoilerPhoto, spoilerIMGID, spoiler
    spoiler = False
    print("Spoiler Set: " + str(spoiler))
    canvasMiataCustom.delete(spoilerIMGID)

def spoilerClicked(event):
    global clickedB1
    clickedB1 += 1

    isOn = (clickedB1 % 2 == 1)

    animateButtonOnOff(canvasMCB1, isOn, "#178B26", "#0f5f1f")

    if isOn:
        spoilerAdd()
    else:
        spoilerRemove()

def rimsAdd():
    global miataRimsPhoto, rimsIMGID, rims
    rims = True
    print("Rims Set: " + str(rims))
    miataRimsIMG = Image.open("miataRims.png")
    miataRimsIMG = miataRimsIMG.resize((550, 135), Image.Resampling.LANCZOS)
    miataRimsPhoto = ImageTk.PhotoImage(miataRimsIMG)

    rimsIMGID = canvasMiataCustom.create_image(375, 170, anchor='center', image=miataRimsPhoto)
    canvasMiataCustom.move(rimsIMGID, 0, 69)

def rimsRemove():
    global miataRimsPhoto, rimsIMGID, rims
    rims = False
    print("Rims Set: " + str(rims))
    canvasMiataCustom.delete(rimsIMGID)

def skirtPackAdd():
    global miataspPhoto, spIMGID, miatasprPhoto, sprIMGID, rims, skirt, sp, spr
    skirt = True
    if rims == False:
        miataspIMG = Image.open("miataSkirtPack.png")
        miataspIMG = miataspIMG.resize((520, 115), Image.Resampling.LANCZOS)
        miataspPhoto = ImageTk.PhotoImage(miataspIMG)

        spIMGID = canvasMiataCustom.create_image(375, 170, anchor='center', image=miataspPhoto)
        canvasMiataCustom.move(spIMGID, -6, 80)
        sp = True
        print("Sp Set: " + str(sp))
    else:
        miatasprIMG = Image.open("miataSkirtPackRims.png")
        miatasprIMG = miatasprIMG.resize((550, 135), Image.Resampling.LANCZOS)
        miatasprPhoto = ImageTk.PhotoImage(miatasprIMG)

        sprIMGID = canvasMiataCustom.create_image(375, 170, anchor='center', image=miatasprPhoto)
        canvasMiataCustom.move(sprIMGID, 0, 69)
        spr = True
        print("Spr Set: " + str(sp))

def skirtPackRemove():
    global spIMGID, miataspIMG, miatasprIMG, spIMGID, skirt, sp, spr
    skirt = False
    if rims == False:
        sp = False
        print("Sp Set: " + str(sp))
        canvasMiataCustom.delete(spIMGID)
    else:
        canvasMiataCustom.delete(sprIMGID)
        spr = False
        print("Spr Set: " + str(spr))


def skirtPackClicked(event):
    global clickedB2
    clickedB2 += 1

    isOn = (clickedB2 % 2 == 1)

    animateButtonOnOff(canvasMCB2, isOn, "#178B26", "#0f5f1f")

    if isOn:
        skirtPackAdd()
    else:
        skirtPackRemove()

def rimsClicked(event):
    global clickedB3
    clickedB3 += 1

    isOn = (clickedB3 % 2 == 1)

    animateButtonOnOff(canvasMCB3, isOn, "#178B26", "#0f5f1f")

    if isOn:
        rimsAdd()
    else:
        rimsRemove()
    checkOverlap()

def colourAdd():
    global miataEyesPhoto, eyesIMGID, eyes
    eyes = True
    print("Eyes Set: " + str(eyes))
    miataEyesIMG = Image.open("miataEyes.png")
    miataEyesIMG = miataEyesIMG.resize((189, 38), Image.Resampling.LANCZOS)
